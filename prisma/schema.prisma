// Prisma schema for CarBlock store.
// Run `npx prisma generate` after editing.
// Run `npx prisma db push` to sync schema to your Neon Postgres DB.

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev (Windows / macOS); the Linux target is what
  // Vercel's serverless runtime needs at request time.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// One row per buyer. Looked up by email; we don't currently authenticate
/// customers, so this is a lightweight contact record built from checkout.
model Customer {
  id            String         @id @default(cuid())
  email         String         @unique
  firstName     String?
  lastName      String?
  phone         String?
  orders        Order[]
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

/// Stripe subscription for the "Subscribe & Save 20% — delivered every 6 weeks"
/// flow. Created by the Stripe webhook on checkout.session.completed when
/// the session was created in subscription mode. Renewals fire invoice.paid
/// and we mirror each one as an Order so the admin/fulfillment view stays
/// consistent across one-off and recurring purchases.
model Subscription {
  id                   String   @id @default(cuid())
  customerId           String
  customer             Customer @relation(fields: [customerId], references: [id])

  stripeSubscriptionId String   @unique
  stripeCustomerId     String
  stripePriceId        String

  productSlug          String
  status               String   @default("active") // active | past_due | canceled | unpaid
  intervalWeeks        Int      @default(6)
  currentPeriodEnd     DateTime?

  // Shipping snapshot — used by the webhook to populate renewal Orders
  shipName             String
  shipAddress          String
  shipCity             String
  shipState            String
  shipZip              String
  shipPhone            String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  canceledAt           DateTime?

  @@index([customerId])
  @@index([status])
}

/// Snapshot of a paid order. Status moves PAID -> SHIPPED -> DELIVERED -> REFUNDED.
/// Created by the Stripe webhook on payment_intent.succeeded.
model Order {
  id                    String      @id @default(cuid())
  /// Human-readable order number shown to customers (CB-XXXXX).
  orderNumber           String      @unique
  customerId            String
  customer              Customer    @relation(fields: [customerId], references: [id])

  // Stripe references
  stripePaymentIntentId String      @unique
  stripeChargeId        String?

  // Money — stored in cents to avoid float drift
  subtotalCents         Int
  shippingCents         Int
  taxCents              Int
  totalCents            Int
  /// Discount applied from a Stripe Promotion Code, in cents. Subtracted from
  /// the subtotal before tax/shipping. 0 when no code was redeemed.
  discountCents         Int         @default(0)
  /// The Stripe Promotion Code string the customer redeemed (e.g. AMAZON15).
  /// Null when no code was used. Source of truth lives in Stripe — this is a
  /// local snapshot for reporting and admin display.
  promoCode             String?
  currency              String      @default("usd")

  // Shipping snapshot (denormalized so we keep history even if customer edits)
  shippingMethod        String      @default("standard") // "standard" | "express"
  shipName              String
  shipAddress           String
  shipCity              String
  shipState             String
  shipZip               String
  shipPhone             String?

  // Fulfillment
  status                OrderStatus @default(PAID)
  trackingNumber        String?
  trackingCarrier       String?     // "USPS" | "UPS" | "FedEx"
  shippedAt             DateTime?
  deliveredAt           DateTime?

  items                 OrderItem[]
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

/// One row per line item in an order. Stores a snapshot of name and price
/// at the moment of purchase so historical orders don't change if the
/// catalog later does.
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productSlug String
  productName String
  unitPriceCents Int
  quantity    Int

  @@index([orderId])
}

enum OrderStatus {
  PAID
  SHIPPED
  DELIVERED
  REFUNDED
  CANCELLED
}
