# Copy this file to .env.local and fill in your Stripe keys.
# .env.local is gitignored and never committed.

# Stripe — get keys from https://dashboard.stripe.com/apikeys
# Use TEST keys (sk_test_, pk_test_) during development.
# Switch to LIVE keys (sk_live_, pk_live_) only in production.
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook signing secret — required for /api/webhooks/stripe.
# Get it from https://dashboard.stripe.com/webhooks after creating the
# endpoint pointing to https://carblock.us/api/webhooks/stripe with events:
#   payment_intent.succeeded, charge.refunded
STRIPE_WEBHOOK_SECRET=whsec_...

# Postgres database — Neon free tier works perfectly.
# Sign up: https://neon.tech → create project → copy the "pooled" connection
# string into DATABASE_URL and the "direct" one into DIRECT_URL (used by
# Prisma migrations).
DATABASE_URL=postgresql://...?sslmode=require
DIRECT_URL=postgresql://...?sslmode=require

# Admin password — protects /admin/* via HTTP Basic Auth.
# Use any browser, username can be anything (admin, you, etc.); only
# this password is checked. Pick something long and unique.
ADMIN_PASSWORD=change-me-to-something-strong

# Resend — transactional email (newsletter signups, contact form, order
# confirmations). Free tier: 100 emails/day, no credit card required.
# Sign up: https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_...

# Optional — override the From / inbox addresses
# Defaults: From "CarBlock <onboarding@resend.dev>" until carblock.us is
# verified in Resend dashboard. Inbox: info@carblock.us
# RESEND_FROM=CarBlock <hello@carblock.us>
# RESEND_INBOX=info@carblock.us

# Meta (Facebook) Pixel ID — public, inlined at build time. From Events Manager.
NEXT_PUBLIC_META_PIXEL_ID=""

# Meta Conversions API (CAPI) access token — SERVER ONLY, never expose to the
# browser. Generate it in Events Manager → Data sources → CarBlock Pixel →
# Settings tab → Conversions API → "Generate access token".
# When set, the Stripe webhook will fire a server-side Purchase event for
# every paid order (deduplicated against the browser Pixel via event_id).
# Leave empty to disable CAPI and run on the browser Pixel only.
META_CAPI_ACCESS_TOKEN=""

# Optional — Meta test event code (TESTXXXXX). When set, every CAPI event is
# tagged so it shows up under Events Manager → Test events for verification.
# REMOVE this in production or events won't count toward your campaigns.
# META_CAPI_TEST_CODE=""
